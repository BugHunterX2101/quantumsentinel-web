# QuantumSentinel — environment configuration
# Copy to .env and fill in as needed. All values are optional; the app
# runs fully end-to-end with sensible in-memory/SQLite defaults.

# --- Web / auth ---
ENVIRONMENT=development
DATABASE_URL=sqlite:///./quantumsentinel.db
JWT_SECRET_KEY=replace-with-a-random-64-char-hex-string
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Alpaca paper trading (optional) ---
# If both are set, live paper orders route to Alpaca instead of the
# built-in simulated broker.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
