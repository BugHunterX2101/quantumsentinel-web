ENVIRONMENT=production

# Required infrastructure credentials. Use Docker/Kubernetes secret mounts in real deployments.
POSTGRES_PASSWORD=replace-with-a-random-32-plus-character-value
REDIS_PASSWORD=replace-with-a-random-32-plus-character-value
DATABASE_URL=postgresql+psycopg://quantumsentinel:REPLACED_BY_COMPOSE@postgres:5432/quantumsentinel
REDIS_URL=redis://:REPLACED_BY_COMPOSE@redis:6379/0

# Stable RS256 PEM keys with literal \n escapes.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Fernet keys; generate with Fernet.generate_key().
WEBHOOK_ENCRYPTION_KEY=
PRIVATE_KEY_ENCRYPTION_KEY=

# Persisted ML-DSA server identity from the managed PQC/HSM service.
SERVER_DSA_PRIVATE_KEY=
SERVER_DSA_PUBLIC_KEY=
SERVER_DSA_CREATED_AT=
PQC_PROVIDER=external
PQC_PROVIDER_URL=https://pqc-provider.internal

CORS_ORIGINS=https://your-domain.example
ALLOWED_HOSTS=your-domain.example
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
